<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container">
    <header>
      <h1><%= title %></h1>
      <p>A simple place to leave a message.</p>
    </header>

    <div class="messages">
      <% for (let i = 0; i < messages.length; i++) { %>
        <div class="message-card">
          <p class="text"><%= messages[i].text %></p>
          <div class="meta">
            <span class="author"><%= messages[i].user %></span>
            <span><%= messages[i].added.toDateString() %></span>
          </div>
        </div>
      <% } %>
    </div>

    <a href="/new" class="btn">+ New Message</a>
  </div>
</body>
</html>