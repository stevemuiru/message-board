<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Mini Messageboard</title>
</head>
<body>

  <ul>
    <% for (let i = 0; i < messages.length; i++) { %>
      <li>
        <span><%= messages[i].user %></span>
        <span><%= messages[i].text %></span>
        <span><%= messages[i].added %></span>
      </li>
    <% } %>
  </ul>

</body>
</html>
